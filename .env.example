# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase Postgres connection pool)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?schema=public
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?schema=public

# WhatsApp Business Number (with country code, no spaces or dashes)
# Format: 92 followed by 10-digit number (e.g., 923001234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# Google Analytics Measurement ID (optional)
# Leave empty if not using Google Analytics
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
