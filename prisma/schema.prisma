// Intikhab Ecommerce — Prisma Schema
// Supabase Postgres database

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  name          String
  brand         String   @default("Intikhab")
  productType   String   @default("shoes") // shoes, bags, accessories, clothing
  category      String   @default("men") // men, women, kids, unisex
  subcategory   String?  // sneakers, formal, casual, sandals, handbags, etc.
  price         Int
  originalPrice Int?
  images        String[]
  badge         String?  // SALE, NEW
  inStock       Boolean  @default(true)
  stock         Int      @default(0)
  installment   Int      @default(0)
  description   String   @default("")
  sku           String   @unique
  status        String   @default("active") // active, draft
  sizeStock     Json     @default("[]") // [{size: string, stock: number, label?: string}]
  sizeSystem    String   @default("eu") // eu, uk, us, bag, general, numeric
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([productType])
  @@index([category])
  @@index([subcategory])
  @@index([status])
  @@index([productType, category])
  @@map("products")
}

model Customer {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  phone        String    @default("")
  fullName     String    @default("")
  createdAt    DateTime  @default(now())
  lastOrderAt  DateTime?

  orders       Order[]
  carts        Cart[]

  @@index([email])
  @@map("customers")
}

model Order {
  id             String      @id // INK-001 format, generated server-side
  customerEmail  String
  customerName   String      @default("")
  shippingAddress String
  province       String      @default("")
  city           String      @default("")
  phone          String      @default("")
  paymentMethod  String      @default("cod") // cod, jazzcash, easypaisa
  orderNotes     String?     @default("")
  total          Int
  status         String      @default("Pending") // Pending, Processing, Shipped, Delivered
  createdAt      DateTime    @default(now())

  customer       Customer    @relation(fields: [customerEmail], references: [email])
  items          OrderItem[]

  @@index([customerEmail])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String
  productId  String
  name       String
  image      String
  quantity   Int
  price      Int
  size       String  // Changed from Int to String for flexible size systems

  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model Cart {
  id             String   @id @default(uuid()) @db.Uuid
  customerEmail  String
  productId      String
  size           String?  // Changed from Int to String for flexible size systems
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer       Customer @relation(fields: [customerEmail], references: [email], onDelete: Cascade)

  @@unique([customerEmail, productId])
  @@index([customerEmail])
  @@map("carts")
}
